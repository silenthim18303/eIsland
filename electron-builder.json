{
  "appId": "com.eisland.app",
  "productName": "eIsland",
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "!out/renderer/.vite/**"
  ],
  "asarUnpack": [
    "node_modules/@eisland/**/src/bin/Release/**/*",
    "node_modules/@eisland/**/*.node",
    "node_modules/koffi/**/*"
  ],
  "extraResources": [
    {
      "from": "resources/icon",
      "to": "icon",
      "filter": ["**/*"]
    },
    {
      "from": "resources/capture.html",
      "to": "capture.html"
    },
    {
      "from": "resources/capture.css",
      "to": "capture.css"
    },
    {
      "from": "resources/capture.js",
      "to": "capture.js"
    },
    {
      "from": "resources/svg",
      "to": "svg",
      "filter": ["**/*"]
    },
    {
      "from": "node_modules/ffmpeg-static/ffmpeg.exe",
      "to": "ffmpeg/ffmpeg.exe"
    }
  ],
  "win": {
    "icon": "resources/icon/eisland_256x256.ico",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-Setup.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "allowElevation": true,
    "deleteAppDataOnUninstall": false
  },
  "publish": {
    "provider": "generic",
    "url": "https://pub-4c1e73c3c2004901aecd6ca014cb16bd.r2.dev"
  }
}
