{
  "name": "@eisland/windows-screenshot-helper",
  "version": "26.0.0",
  "description": "High-performance Windows screen capture via Native AOT DLL and JS FFI.",
  "author": "JNTMTMTM",
  "license": "GPL-3.0",
  "main": "index.js",
  "types": "index.d.ts",
  "os": [
    "win32"
  ],
  "cpu": [
    "x64"
  ],
  "scripts": {
    "postinstall": "dotnet publish src/eIslandScreenshotHelper.csproj -c Release -r win-x64",
    "build": "dotnet publish src/eIslandScreenshotHelper.csproj -c Release -r win-x64",
    "clean": "dotnet clean src/eIslandScreenshotHelper.csproj",
    "rebuild": "npm run clean && npm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:screenshot": "vitest run --config vitest.config.ts test/screenshot.test.ts",
    "smoke": "node --experimental-strip-types test/screenshot.smoke.ts"
  },
  "dependencies": {
    "koffi": "^2.9.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.4"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "ffi-loader.js",
    "src"
  ]
}