{
  "name": "@eisland/windows-power-helper",
  "version": "26.0.0",
  "description": "Windows battery status and power event monitoring via Native AOT DLL.",
  "author": "JNTMTMTM",
  "license": "GPL-3.0",
  "main": "index.js",
  "types": "index.d.ts",
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64",
    "ia32"
  ],
  "scripts": {
    "postinstall": "npm run build:all",
    "build": "dotnet publish src/eIslandPowerHelper.csproj -c Release -r win-x64",
    "build:ctypes": "dotnet publish pw-ctypes/eIslandPowerCtypes.csproj -c Release -r win-x64",
    "build:all": "npm run build && npm run build:ctypes",
    "clean": "dotnet clean src/eIslandPowerHelper.csproj && dotnet clean pw-ctypes/eIslandPowerCtypes.csproj",
    "rebuild": "npm run clean && npm run build:all",
    "test": "vitest run --config vitest.config.ts",
    "test:query": "vitest run --config vitest.config.ts test/power.test.ts",
    "test:monitor": "vitest run --config vitest.config.ts test/power.monitor.test.ts",
    "smoke": "node --experimental-strip-types test/power.smoke.ts",
    "smoke:monitor": "node --experimental-strip-types test/power.monitor.smoke.ts"
  },
  "dependencies": {
    "koffi": "^2.9.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "ffi-loader.js",
    "power-monitor.js",
    "src",
    "pw-ctypes"
  ]
}
