{
  "name": "@eisland/windows-performance-monitor",
  "version": "26.0.1",
  "description": "Windows N-API addon for low-overhead CPU, memory, and temperature performance snapshots.",
  "author": "JNTMTMTM",
  "license": "GPL-3.0",
  "main": "index.js",
  "types": "index.d.ts",
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64",
    "ia32"
  ],
  "scripts": {
    "postinstall": "dotnet build temperature-helper/eIslandTemperatureReader.csproj -c Release",
    "build": "node-gyp rebuild && dotnet build temperature-helper/eIslandTemperatureReader.csproj -c Release",
    "clean": "node-gyp clean && dotnet clean temperature-helper/eIslandTemperatureReader.csproj",
    "rebuild": "node-gyp clean && node-gyp rebuild && dotnet build temperature-helper/eIslandTemperatureReader.csproj -c Release",
    "test": "vitest run --config vitest.config.ts",
    "smoke": "node --experimental-strip-types test/performance-monitor.smoke.ts",
    "smoke:polling": "node --experimental-strip-types test/performance-monitor.polling.smoke.ts"
  },
  "dependencies": {
    "node-gyp": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3"
  },
  "gypfile": true,
  "files": [
    "index.js",
    "index.d.ts",
    "binding.gyp",
    "src",
    "temperature-helper"
  ]
}