{
  "name": "@eisland/windows-performance-monitor",
  "version": "26.0.1",
  "description": "Windows N-API addon for low-overhead CPU and memory performance snapshots.",
  "author": "JNTMTMTM",
  "license": "GPL-3.0",
  "main": "index.js",
  "types": "index.d.ts",
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64",
    "ia32"
  ],
  "scripts": {
    "build": "node-gyp rebuild",
    "clean": "node-gyp clean",
    "rebuild": "node-gyp clean && node-gyp rebuild",
    "test": "vitest run --config vitest.config.ts",
    "smoke": "node --experimental-strip-types test/performance-monitor.smoke.ts",
    "smoke:polling": "node --experimental-strip-types test/performance-monitor.polling.smoke.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "node-gyp": "^11.2.0"
  },
  "gypfile": true,
  "files": [
    "index.js",
    "index.d.ts",
    "binding.gyp",
    "src"
  ]
}