{
  "name": "eisland",
  "version": "26.5.10",
  "description": "A sleek, Apple Dynamic Island inspired floating widget for Windows, built with Electron.",
  "main": "./out/main/index.js",
  "author": "JNTMTMTM",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:preload": "vitest run src/preload/index.test.ts",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder",
    "changelog:generate": "node --experimental-strip-types scripts/generate-changelog.ts -o docs/CHANGE_LOG.md",
    "release:notes": "node --experimental-strip-types scripts/generate-incremental-release-notes.ts -o RELEASE_NOTES_SINCE_LAST_TAG.md",
    "release:upload": "npm run package && node --experimental-strip-types scripts/upload-release-to-cos-oss.ts",
    "release:upload-only": "node --experimental-strip-types scripts/upload-release-to-cos-oss.ts",
    "comment:check": "node --experimental-strip-types scripts/check-comment-standards.ts"
  },
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12",
    "@tailwindcss/vite": "^4.2.2",
    "colorthief": "^3.3.1",
    "electron-updater": "^6.8.3",
    "fetch-installed-software": "^0.0.7",
    "get-windows": "^9.3.0",
    "i18next": "^25.6.0",
    "imapflow": "^1.3.3",
    "lunar-javascript": "^1.7.7",
    "lyric-resolver": "^0.1.6",
    "mailparser": "^3.9.8",
    "open": "^11.0.0",
    "openmeteo": "^1.2.3",
    "react-datepicker": "^9.1.0",
    "react-i18next": "^15.7.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "systeminformation": "^5.31.6",
    "uapi-sdk-typescript": "^0.1.14",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.0",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.511.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
