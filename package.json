{
  "name": "eisland",
  "version": "26.6.4",
  "description": "A sleek, Apple Dynamic Island inspired floating widget for Windows, built with Electron.",
  "main": "./out/main/index.js",
  "author": "JNTMTMTM",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:preload": "vitest run src/preload/index.test.ts",
    "test:coverage": "vitest run --coverage",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder",
    "changelog:generate": "node --experimental-strip-types scripts/generate-changelog.ts -o docs/CHANGE_LOG.md",
    "release:notes": "node --experimental-strip-types scripts/generate-incremental-release-notes.ts -o RELEASE_NOTES_SINCE_LAST_TAG.md",
    "release:upload": "npm run package && node --experimental-strip-types scripts/upload-release-to-cos-oss.ts && npm run esa:purge",
    "release:upload-only": "node --experimental-strip-types scripts/upload-release-to-cos-oss.ts && npm run esa:purge",
    "release:upload-minio": "node --experimental-strip-types scripts/upload-release-to-cos-oss.ts --minio-only && npm run esa:purge",
    "comment:check": "node --experimental-strip-types scripts/check-comment-standards.ts",
    "i18n:check": "node --experimental-strip-types scripts/check-i18n-completeness.ts",
    "esa:purge": "node --experimental-strip-types scripts/esa/purge-esa-cache.ts",
    "esa:purge-hostname": "node --experimental-strip-types scripts/esa/purge-esa-hostname.ts",
    "esa:purge-all": "node --experimental-strip-types scripts/esa/purge-esa-hostname.ts --purge-all",
    "plugin:build:bluetooth": "cd plugins/eisland-windows-bluetooth-helper && npm run build:all",
    "plugin:build:brightness": "cd plugins/eisland-windows-brightness-helper && npm run build",
    "plugin:build:power": "cd plugins/eisland-windows-power-helper && npm run build:all",
    "plugin:build:processes": "cd plugins/eisland-windows-processes-attacker && npm run build",
    "plugin:build:smtc": "cd plugins/eisland-windows-smtc-helper && npm run build:all",
    "plugin:build:toast": "cd plugins/eisland-windows-toast-listener && npm run build",
    "plugin:build:wifi": "cd plugins/eisland-windows-wifi-helper && npm run build:all",
    "plugin:build:fullscreen": "cd plugins/eisland-windows-fullscreen-detector && npm run build",
    "plugin:build:perfmon": "cd plugins/eisland-windows-performance-monitor && npm run build",
    "plugin:clean:bluetooth": "cd plugins/eisland-windows-bluetooth-helper && npm run clean",
    "plugin:clean:brightness": "cd plugins/eisland-windows-brightness-helper && npm run clean",
    "plugin:clean:power": "cd plugins/eisland-windows-power-helper && npm run clean",
    "plugin:clean:processes": "cd plugins/eisland-windows-processes-attacker && npm run clean",
    "plugin:clean:smtc": "cd plugins/eisland-windows-smtc-helper && npm run clean",
    "plugin:clean:toast": "cd plugins/eisland-windows-toast-listener && npm run clean",
    "plugin:clean:wifi": "cd plugins/eisland-windows-wifi-helper && npm run clean",
    "plugin:clean:fullscreen": "cd plugins/eisland-windows-fullscreen-detector && npm run clean",
    "plugin:clean:perfmon": "cd plugins/eisland-windows-performance-monitor && npm run clean",
    "plugins:build": "run-s plugin:build:bluetooth plugin:build:brightness plugin:build:power plugin:build:processes plugin:build:smtc plugin:build:toast plugin:build:wifi plugin:build:fullscreen plugin:build:perfmon",
    "plugins:clean": "run-p plugin:clean:bluetooth plugin:clean:brightness plugin:clean:power plugin:clean:processes plugin:clean:smtc plugin:clean:toast plugin:clean:wifi plugin:clean:fullscreen plugin:clean:perfmon"
  },
  "dependencies": {
    "@eisland/windows-application-icon-helper": "file:plugins/eisland-windows-application-icon-helper",
    "@eisland/windows-bluetooth-helper": "file:plugins/eisland-windows-bluetooth-helper",
    "@eisland/windows-brightness-helper": "file:plugins/eisland-windows-brightness-helper",
    "@eisland/windows-fullscreen-detector": "file:plugins/eisland-windows-fullscreen-detector",
    "@eisland/windows-performance-monitor": "file:plugins/eisland-windows-performance-monitor",
    "@eisland/windows-power-helper": "file:plugins/eisland-windows-power-helper",
    "@eisland/windows-processes-attacker": "file:plugins/eisland-windows-processes-attacker",
    "@eisland/windows-smtc-helper": "file:plugins/eisland-windows-smtc-helper",
    "@eisland/windows-toast-listener": "file:plugins/eisland-windows-toast-listener",
    "@eisland/windows-wifi-helper": "file:plugins/eisland-windows-wifi-helper",
    "@gsap/react": "^2.1.2",
    "@tailwindcss/vite": "^4.2.2",
    "colorthief": "^3.3.1",
    "dompurify": "^3.4.9",
    "electron-updater": "^6.8.3",
    "fetch-installed-software": "^0.0.7",
    "get-windows": "^9.3.0",
    "gsap": "^3.15.0",
    "highcharts": "^13.0.0",
    "highcharts-react-official": "^3.2.3",
    "i18next": "^25.6.0",
    "imapflow": "^1.3.3",
    "lunar-javascript": "^1.7.7",
    "lyric-resolver": "^0.1.6",
    "mailparser": "^3.9.8",
    "open": "^11.0.0",
    "openmeteo": "^1.2.3",
    "react-datepicker": "^9.1.0",
    "react-i18next": "^15.7.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stock-api": "^2.7.2",
    "systeminformation": "^5.31.6",
    "uapi-sdk-typescript": "^0.1.14",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@alicloud/credentials": "^2.4.5",
    "@alicloud/esa20240910": "^3.5.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@alicloud/tea-util": "^1.4.11",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.19.20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.0.0",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^0.511.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^2.1.9"
  }
}
